{
  "name": "ai-bubble-bust-simulation",
  "version": "7.0.0",
  "description": "AI bubble-bust market simulation dashboard — nine dials, 26,244 scenarios, with live financial-news analysis.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "simulate": "tsx src/simulate.ts",
    "fetch-news": "tsx src/fetchNews.ts",
    "build": "tsx src/build.ts",
    "serve": "tsx src/server.ts",
    "start": "tsx src/server.ts",
    "compile": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
